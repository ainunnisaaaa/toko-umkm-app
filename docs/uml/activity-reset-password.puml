@startuml
|Guest|
start
:Membuka halaman Lupa Password;
:Menginput Email terdaftar;
:Menekan tombol "Kirim Link Reset";
|Sistem|
:Validasi keberadaan Email;
if (Email ada di DB?) then (Ya)
  :Generate token reset password;
  :Simpan token ke DB (dengan batas waktu);
  :Kirim email berisi link reset password;
  |Guest|
  :Menampilkan pesan "Cek Email Anda";
  :Membuka email dan mengklik link reset;
  |Sistem|
  :Validasi token (Apakah kadaluarsa?);
  if (Token Valid?) then (Ya)
    |Guest|
    :Menampilkan form password baru;
    :Input password baru dan konfirmasi;
    |Sistem|
    :Update password pengguna;
    :Hapus token dari DB;
    :Redirect ke halaman Login;
  else (Tidak)
    :Tampilkan pesan "Token tidak valid / expired";
  endif
else (Tidak)
  :Tampilkan pesan "Email tidak ditemukan";
endif
|Guest|
stop
@enduml
