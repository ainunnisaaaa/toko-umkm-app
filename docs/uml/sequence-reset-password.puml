@startuml
actor Guest
participant "View" as V
participant "Routes" as R
participant "PasswordResetController" as C
participant "User/Token (Model)" as M
participant "Mail/Email Package" as E

Guest -> V : Membuka halaman Lupa Password
Guest -> V : Menginput Email terdaftar
Guest -> V : Menekan tombol "Kirim Link Reset"
V -> R : POST /password/email
R -> C : sendResetLinkEmail()
C -> M : Validasi keberadaan Email
M --> C : Status Email
alt Email ada di DB?
    C -> C : Generate token reset password
    C -> M : Simpan token ke DB (dengan batas waktu)
    C -> E : Kirim email berisi link reset password
    E --> C : Email Terkirim
    C --> V : Return Success
    V --> Guest : Menampilkan pesan "Cek Email Anda"
    Guest -> Guest : Membuka email dan mengklik link reset
    Guest -> V : Membuka Link Reset
    V -> R : GET /password/reset/{token}
    R -> C : showResetForm()
    C -> M : Validasi token (Apakah kadaluarsa?)
    M --> C : Status Token
    alt Token Valid?
        C --> V : Tampilkan form password baru
        V --> Guest : Form Reset
        Guest -> V : Input password baru dan konfirmasi
        V -> R : POST /password/reset
        R -> C : reset()
        C -> M : Update password pengguna
        C -> M : Hapus token dari DB
        C --> V : Redirect ke halaman Login
        V --> Guest : Tampilkan halaman Login
    else Tidak (Invalid/Expired)
        C --> V : Redirect Back with Error
        V --> Guest : Tampilkan pesan "Token tidak valid / expired"
    end
else Tidak (Email tidak ditemukan)
    C --> V : Redirect Back with Error
    V --> Guest : Tampilkan pesan "Email tidak ditemukan"
end
@enduml
